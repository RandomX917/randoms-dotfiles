{
  "layer": "bottom",
  "position": "bottom",
  "height": 42,
  "spacing": 5,
  "exclusive": true,
  "gtk-layer-shell": true,
  "passthrough": false,
  "fixed-center": true,

  "modules-left": [
    "custom/rofi",
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "custom/rofi": {
    "tooltip": false,
    "on-click": "rofi -show drun",
    "format": ""
  },
}
